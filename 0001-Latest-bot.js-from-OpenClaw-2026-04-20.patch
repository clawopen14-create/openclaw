+    homeDir ? path.resolve(homeDir, `.openclaw/agents/your-agent/skills/${skillName}/SKILL.md`) : "",
+    homeDir ? path.resolve(homeDir, `.openclaw/skills/${skillName}/SKILL.md`) : "",
