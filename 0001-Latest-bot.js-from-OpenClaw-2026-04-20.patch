+  if (/self[- ]improv|skill|hook/.test(text)) {
+    addIfInstalled("self-improving");
+    addIfInstalled("self-improving-agent");
+    addIfInstalled("skill-creator");
+    addIfInstalled("skill-vetter");
+  }
